{
  "Khung Competitive Programming (C++)": {
    "prefix": "cp",
    "body":[
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "// --- Macros ---",
      "#define int long long",
      "#define pb push_back",
      "#define all(x) (x).begin(), (x).end()",
      "#define sz(x) ((int)(x).size())",
      "#define endl '\\n'",
      "",
      "const int INF = 1e18;",
      "const int MOD = 1e9 + 7;",
      "",
      "void solve() {",
      "\t${0:// Code here}",
      "}",
      "",
      "int32_t main() {",
      "\tios_base::sync_with_stdio(false);",
      "\tcin.tie(NULL);",
      "\tint t = 1;",
      "\t${1:cin >> t;}",
      "\twhile (t--) {",
      "\t\tsolve();",
      "\t}",
      "\treturn 0;",
      "}"
    ],
    "description": "Boilerplate chuẩn thi đấu thuật toán"
  },
  "Hàm Main tiêu chuẩn (Basic)": {
    "prefix": "main",
    "body":[
      "#include <iostream>",
      "using namespace std;",
      "",
      "int main() {",
      "\tios_base::sync_with_stdio(false);",
      "\tcin.tie(nullptr);",
      "\t${1:// Code của bạn ở đây}",
      "\treturn 0;",
      "}"
    ],
    "description": "Hàm main cơ bản cho các bài tập thông thường"
  },
  "Vòng lặp For Tăng": {
    "prefix": "fori",
    "body":[
      "for (int ${1:i} = 0; ${1:i} < ${2:n}; ++${1:i}) {",
      "\t$3",
      "}"
    ],
    "description": "Vòng lặp từ 0 đến n-1"
  },
  "Vòng lặp For Giảm": {
    "prefix": "forrev",
    "body":[
      "for (int ${1:i} = ${2:n} - 1; ${1:i} >= 0; --${1:i}) {",
      "\t$3",
      "}"
    ],
    "description": "Vòng lặp ngược từ n-1 về 0"
  },
  "Nhập mảng nhanh": {
    "prefix": "cinv",
    "body": [
      "for (int &x : ${1:v}) cin >> x;"
    ],
    "description": "Nhập nhanh dữ liệu vào mảng/vector"
  },
  "In mảng nhanh": {
    "prefix": "coutv",
    "body":[
      "for (int x : ${1:v}) cout << x << \" \";",
      "cout << endl;"
    ],
    "description": "In mảng/vector trên 1 dòng"
  },
  "Đọc/Ghi File nhanh (File I/O)": {
    "prefix": "fio",
    "body":[
      "if (fopen(\"${1:input.txt}\", \"r\")) {",
      "\tfreopen(\"${1:input.txt}\", \"r\", stdin);",
      "\tfreopen(\"${2:output.txt}\", \"w\", stdout);",
      "}"
    ],
    "description": "Chuyển I/O từ console sang file"
  },
  "Ước chung lớn nhất & Bội chung nhỏ nhất": {
    "prefix": "gcd",
    "body":[
      "long long gcd(long long a, long long b) {",
      "\treturn b == 0 ? a : gcd(b, a % b);",
      "}",
      "long long lcm(long long a, long long b) {",
      "\treturn a / gcd(a, b) * b;",
      "}"
    ],
    "description": "Hàm tính UCLN và BCNN"
  },
  "Tìm kiếm nhị phân (Binary Search)": {
    "prefix": "bs",
    "body":[
      "int l = ${1:0}, r = ${2:n - 1}, ans = ${3:-1};",
      "while (l <= r) {",
      "\tint mid = l + (r - l) / 2;",
      "\tif (${4:/* Điều kiện thoả mãn */}) {",
      "\t\tans = mid;",
      "\t\t${5:l = mid + 1};",
      "\t} else {",
      "\t\t${6:r = mid - 1};",
      "\t}",
      "}"
    ],
    "description": "Mẫu vòng lặp Binary Search"
  },
  "Thuật toán: Depth First Search (DFS)": {
    "prefix": "dfs",
    "body":[
      "void dfs(int u, int p = -1) {",
      "\tfor (int v : adj[u]) {",
      "\t\tif (v == p) continue;",
      "\t\t${1:// Xử lý logic tại đây}",
      "\t\tdfs(v, u);",
      "\t}",
      "}"
    ],
    "description": "Duyệt đồ thị DFS"
  },
  "Thuật toán: Sàng nguyên tố": {
    "prefix": "sieve",
    "body":[
      "const int MAXN = ${1:1e6 + 5};",
      "vector<bool> is_prime(MAXN, true);",
      "void sieve() {",
      "\tis_prime[0] = is_prime[1] = false;",
      "\tfor (int i = 2; i * i < MAXN; i++) {",
      "\t\tif (is_prime[i]) {",
      "\t\t\tfor (int j = i * i; j < MAXN; j += i)",
      "\t\t\t\tis_prime[j] = false;",
      "\t\t}",
      "\t}",
      "}"
    ],
    "description": "Tìm số nguyên tố nhanh"
  },
  "Khai báo lớp đầy đủ": {
    "prefix": "class",
    "body": [
      "class ${1:ClassName} {",
      "private:",
      "\t${2:// Thuộc tính}",
      "public:",
      "\t${1:ClassName}();",
      "\t~${1:ClassName}();",
      "};$0"
    ],
    "description": "Khung lớp đầy đủ với public/private, constructor và destructor"
  },
  "Constructor với danh sách khởi tạo": {
    "prefix": "ctor",
    "body": [
      "${1:ClassName}::${1:ClassName}(${2:type} ${3:param}) : ${4:member}(${3:param}) {",
      "\t$0",
      "}"
    ],
    "description": "Hàm tạo với danh sách khởi tạo thành viên"
  },
  "Destructor ảo": {
    "prefix": "dtor",
    "body": [
      "virtual ~${1:ClassName}() = default;"
    ],
    "description": "Hàm huỷ ảo mặc định"
  },
  "Getter và Setter": {
    "prefix": "getset",
    "body": [
      "${1:type} get${2:Name}() const { return ${3:name}; }",
      "void set${2:Name}(${1:type} ${3:name}) { this->${3:name} = ${3:name}; }"
    ],
    "description": "Cặp hàm getter và setter cho thuộc tính"
  },
  "Kế thừa lớp": {
    "prefix": "inh",
    "body": [
      "class ${1:Derived} : public ${2:Base} {",
      "public:",
      "\t${1:Derived}();",
      "\t~${1:Derived}() override;",
      "};$0"
    ],
    "description": "Lớp kế thừa từ lớp cha"
  },
  "Toán tử xuất <<": {
    "prefix": "op<<",
    "body": [
      "friend ostream& operator<<(ostream& os, const ${1:ClassName}& ${2:obj}) {",
      "\tos << ${2:obj}.${3:member};",
      "\treturn os;",
      "}"
    ],
    "description": "Nạp chồng toán tử xuất ostream"
  },
  "Khối try-catch": {
    "prefix": "try",
    "body": [
      "try {",
      "\t${1:// Mã lệnh}",
      "} catch (const ${2:exception}& ${3:e}) {",
      "\tcerr << ${3:e}.what() << endl;",
      "}"
    ],
    "description": "Khối bắt ngoại lệ try-catch"
  },
  "Vòng lặp for theo phạm vi": {
    "prefix": "foreach",
    "body": [
      "for (const auto& ${1:item} : ${2:container}) {",
      "\t$0",
      "}"
    ],
    "description": "Vòng lặp range-based for duyệt phần tử"
  },
  "Biểu thức Lambda": {
    "prefix": "lambda",
    "body": [
      "auto ${1:func} = [](${2:type} ${3:param}) -> ${4:returnType} {",
      "\treturn ${5:result};",
      "};"
    ],
    "description": "Biểu thức lambda với tham số và kiểu trả về"
  },
  "Khai báo Vector": {
    "prefix": "vec",
    "body": [
      "vector<${1:type}> ${2:name}(${3:n});"
    ],
    "description": "Khai báo vector với kích thước cho trước"
  },
  "Xuất nhanh cout": {
    "prefix": "cout",
    "body": [
      "cout << ${1:value} << endl;"
    ],
    "description": "In giá trị ra màn hình với xuống dòng"
  },
  "Nhập nhanh cin": {
    "prefix": "cin",
    "body": [
      "cin >> ${1:variable};"
    ],
    "description": "Nhập giá trị từ bàn phím"
  }
}
